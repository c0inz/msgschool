# Copy to .env.local and fill in real values. Never commit .env.local.

# --- Database ---
# Production reuses the existing msgschool droplet's Postgres — same DB as
# OCMarketplace. Our tables are prefixed `ms_` to coexist with OCM's tables
# in the default public schema.
# Local dev can point at a local Postgres or SSH-tunnel to the droplet's 5432.
DATABASE_URL=postgres://msgschool:CHANGEME@localhost:5432/msgschool

# --- Public site ---
NEXT_PUBLIC_SITE_URL=https://msgschool.com
NEXT_PUBLIC_TELEGRAM_BOT_HANDLE=MsgSchoolBot

# --- Telegram bot ---
# Obtain from @BotFather. Leave blank in dev — bot wiring is gated on this.
TELEGRAM_BOT_TOKEN=
# Webhook secret — arbitrary strong string; Telegram will send this in a header.
TELEGRAM_WEBHOOK_SECRET=

# --- Provisioning ---
# Base dir for per-user workspaces created on first paid/free-code contact.
USER_WORKSPACE_ROOT=/opt/msgschool/users
# Path to the provision script.
PROVISION_SCRIPT=./scripts/provision-workspace.sh

# --- Free code ---
FREE_CODE=FreeAgent2026
FREE_CODE_PERIOD_DAYS=30

# --- Paid plan (aspirational) ---
PRICE_USD_PER_MONTH=5
